{
    "name": "inboxcom/mailcore-laravel",
    "description": "Laravel integration (service provider + facade) for the Mailcore PHP client.",
    "type": "library",
    "license": "MIT",
    "authors": [
        { "name": "Sebastian Karlsen", "email": "sebastian@corp.inbox.com" }
    ],
    "require": {
        "php": ">=8.4",
        "inboxcom/mailcore-php": "^0.1",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Inboxcom\\Mailcore\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Inboxcom\\Mailcore\\Laravel\\MailcoreServiceProvider"
            ],
            "aliases": {
                "Mailcore": "Inboxcom\\Mailcore\\Laravel\\Facades\\Mailcore"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
